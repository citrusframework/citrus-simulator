{
  "name": "citrus-simulator",
  "version": "0.0.0",
  "private": true,
  "description": "Description for Citrus Simulator",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "npm run webapp:prod --",
    "build-watch": "concurrently 'npm run webapp:build:dev -- --watch'",
    "ci:frontend:build": "npm run webapp:build:$npm_package_config_default_environment",
    "ci:frontend:test": "npm run ci:frontend:build && npm test",
    "clean-www": "rimraf target/classes/static/simulator-ui/app/{src,target/}",
    "cleanup": "rimraf target/classes/static/simulator-ui/",
    "e2e": "playwright test",
    "e2e:open": "npm run e2e -- --ui",
    "jest": "jest --coverage --logHeapUsage --maxWorkers=2 --config jest.conf.js",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "prettier:check": "prettier --check \"{,src/**/,webpack/,.blueprint/**/,./test/**/}*.{md,json,yml,html,cjs,mjs,js,ts,tsx,css,scss}\"",
    "prettier:format": "prettier --write \"{,src/**/,webpack/,.blueprint/**/,./test/**/}*.{md,json,yml,html,cjs,mjs,js,ts,tsx,css,scss}\"",
    "serve": "npm run start --",
    "start": "ng serve --hmr",
    "start-tls": "npm run webapp:dev-ssl",
    "pretest": "npm run lint",
    "test": "ng test --coverage --log-heap-usage -w=2",
    "test:watch": "npm run test -- --watch",
    "watch": "concurrently npm:start",
    "webapp:build": "npm run clean-www && npm run webapp:build:dev",
    "webapp:build:dev": "ng build --configuration development",
    "webapp:build:prod": "ng build --configuration production",
    "webapp:dev": "ng serve",
    "webapp:dev-ssl": "ng serve --ssl",
    "webapp:dev-verbose": "ng serve --verbose",
    "webapp:prod": "npm run clean-www && npm run webapp:build:prod",
    "webapp:test": "npm run test --"
  },
  "config": {
    "backend_port": 8080,
    "default_environment": "prod"
  },
  "overrides": {
    "browser-sync": "3.0.4",
    "webpack": "5.103.0"
  },
  "dependencies": {
    "@angular/common": "21.2.13",
    "@angular/compiler": "21.2.13",
    "@angular/core": "21.2.13",
    "@angular/forms": "21.2.13",
    "@angular/localize": "21.2.13",
    "@angular/platform-browser": "21.2.13",
    "@angular/platform-browser-dynamic": "21.2.13",
    "@angular/router": "21.2.13",
    "@fortawesome/angular-fontawesome": "4.0.0",
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/free-brands-svg-icons": "7.2.0",
    "@fortawesome/free-solid-svg-icons": "7.2.0",
    "@ng-bootstrap/ng-bootstrap": "20.0.0",
    "@ngx-translate/core": "17.0.0",
    "@ngx-translate/http-loader": "17.0.0",
    "axios": "1.16.1",
    "bootstrap": "5.3.8",
    "bootswatch": "5.3.8",
    "dayjs": "1.11.20",
    "mdb-angular-ui-kit": "10.0.0",
    "ngx-highlightjs": "14.0.1",
    "ngx-infinite-scroll": "21.0.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "21.0.3",
    "@angular-builders/jest": "21.0.3",
    "@angular-devkit/build-angular": "21.2.11",
    "@angular-eslint/eslint-plugin": "21.4.0",
    "@angular/cli": "21.2.11",
    "@angular/compiler-cli": "21.2.13",
    "@angular/service-worker": "21.2.13",
    "@playwright/test": "1.60.0",
    "@types/jest": "30.0.0",
    "@types/node": "25.8.0",
    "angular-eslint": "21.4.0",
    "browser-sync": "3.0.4",
    "browser-sync-v3-webpack-plugin": "0.1.1",
    "buffer": "6.0.3",
    "concurrently": "9.2.1",
    "copy-webpack-plugin": "14.0.0",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-webpack-plugin": "6.0.0",
    "folder-hash": "4.1.2",
    "generator-jhipster": "9.0.0",
    "jest": "30.4.2",
    "jest-date-mock": "1.0.10",
    "jest-environment-jsdom": "30.4.1",
    "jest-junit": "17.0.0",
    "jest-preset-angular": "16.1.5",
    "jest-sonar": "0.2.16",
    "jiti": "2.7.0",
    "merge-jsons-webpack-plugin": "2.0.1",
    "prettier": "3.8.3",
    "prettier-plugin-packagejson": "3.0.2",
    "rimraf": "6.1.3",
    "swagger-ui-dist": "5.32.6",
    "ts-jest": "29.4.9",
    "typescript": "<6.1",
    "typescript-eslint": "8.59.3",
    "webpack-bundle-analyzer": "5.3.0",
    "webpack-merge": "6.0.1",
    "webpack-notifier": "1.15.0"
  },
  "optionalDependencies": {
    "npm-check-updates": "22.2.0"
  },
  "engines": {
    "node": ">=24.11.1"
  }
}
